{
  "name": "mockifyer-monorepo",
  "version": "1.8.1",
  "private": true,
  "description": "Monorepo for Mockifyer libraries: @sgedda/mockifyer-core, @sgedda/mockifyer-axios, @sgedda/mockifyer-fetch, @sgedda/mockifyer-dashboard, @sgedda/mockifyer-test-helper",
  "scripts": {
    "build": "sh packages/build-all.sh",
    "start": "npm run start --prefix mockifyer-web",
    "test": "jest",
    "test:axios": "MOCKIFYER_ENABLED=true MOCKIFYER_RECORD=true npx ts-node tests/axios/axios-auto-mock.ts",
    "test:axios:local": "MOCKIFYER_ENABLED=true MOCKIFYER_RECORD=true npx ts-node tests/axios/axios-local-mock.ts",
    "test:fetch": "MOCKIFYER_ENABLED=true MOCKIFYER_RECORD=true npx ts-node tests/fetch/fetch-auto-mock.ts",
    "test:watch": "jest --watch",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "retag:latest": "bash scripts/retag-latest.sh",
    "registry:delete-legacy-mockifyer": "sh scripts/delete-github-packages-legacy-mockifyer.sh"
  },
  "keywords": [
    "mock",
    "api",
    "testing",
    "http",
    "intercept"
  ],
  "author": "sgedda",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "axios": "^1.6.7",
    "axios-mock-adapter": "^1.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgedda/mockifyer.git"
  },
  "bugs": {
    "url": "https://github.com/sgedda/mockifyer/issues"
  },
  "homepage": "https://github.com/sgedda/mockifyer#readme"
}
