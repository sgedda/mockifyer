{
  "name": "@sgedda/mockifyer-fetch",
  "version": "1.8.4",
  "description": "Mockifyer for Fetch - API mocking and logging utility for storing and replaying API responses",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "dist/react-native.js",
  "exports": {
    ".": {
      "react-native": "./dist/react-native.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "default": "./dist/react-native.js"
    },
    "./metro-config": {
      "types": "./dist/metro-config.d.ts",
      "default": "./dist/metro-config.js"
    },
    "./metro-sync-middleware": {
      "types": "./dist/metro-sync-middleware.d.ts",
      "default": "./dist/metro-sync-middleware.js"
    },
    "./test-generation-hook": {
      "types": "./dist/test-generation-hook.d.ts",
      "default": "./dist/test-generation-hook.js"
    },
    "./metro-polyfills/empty-module": {
      "default": "./metro-polyfills/empty-module.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "keywords": [
    "mock",
    "api",
    "testing",
    "http",
    "intercept",
    "fetch"
  ],
  "author": "sgedda",
  "license": "MIT",
  "dependencies": {
    "@sgedda/mockifyer-core": "file:../mockifyer-core"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgedda/mockifyer.git"
  }
}
