{
  "name": "@sgedda/mockifyer-core",
  "version": "1.8.9",
  "description": "Core utilities and types for Mockifyer",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "./dist/index.react-native.js",
  "exports": {
    ".": {
      "react-native": "./dist/index.react-native.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./utils/build-utils": {
      "types": "./dist/utils/build-utils.d.ts",
      "default": "./dist/utils/build-utils.js"
    }
  },
  "bin": {
    "mockifyer": "./src/cli/generate-bundle.ts",
    "mockifyer-sync-to-device": "./src/cli/sync-to-device.ts",
    "mockifyer-sync-from-device": "./src/cli/sync-from-device.ts"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "example:build": "ts-node examples/build-example.ts"
  },
  "keywords": [
    "mock",
    "api",
    "testing",
    "http",
    "intercept"
  ],
  "author": "sgedda",
  "license": "MIT",
  "peerDependencies": {
    "ioredis": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "ioredis": "^5.6.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgedda/mockifyer.git"
  }
}
