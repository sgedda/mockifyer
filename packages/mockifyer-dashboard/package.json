{
  "name": "@sgedda/mockifyer-dashboard",
  "version": "1.4.4",
  "description": "Standalone CLI dashboard for viewing and managing Mockifyer mock data",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": {
    "mockifyer-dashboard": "./bin/mockifyer-dashboard"
  },
  "files": [
    "bin",
    "dist",
    "public"
  ],
  "scripts": {
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "tsc && chmod +x bin/mockifyer-dashboard",
    "watch": "tsc --watch",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "dev:watch": "nodemon --exec ts-node src/cli.ts --watch src --watch public",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\""
  },
  "keywords": [
    "mock",
    "dashboard",
    "api",
    "testing",
    "mockifyer"
  ],
  "author": "sgedda",
  "license": "MIT",
  "dependencies": {
    "@sgedda/mockifyer-core": "file:../mockifyer-core",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "ioredis": "^5.6.1",
    "open": "^8.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgedda/mockifyer.git"
  }
}
