{
  "name": "@sgedda/mockifyer-axios",
  "version": "1.9.1",
  "description": "Mockifyer for Axios - API mocking and logging utility for storing and replaying API responses",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "dist/index.js",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "keywords": [
    "mock",
    "api",
    "testing",
    "http",
    "intercept",
    "axios"
  ],
  "author": {
    "name": "Sebastian Gedda",
    "url": "https://github.com/sgedda"
  },
  "license": "MIT",
  "dependencies": {
    "@sgedda/mockifyer-core": "file:../mockifyer-core",
    "axios-mock-adapter": "^1.22.0"
  },
  "peerDependencies": {
    "axios": "^1.6.0 || ^1.7.0",
    "react-native-launch-arguments": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": false
    },
    "react-native-launch-arguments": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://mockifyer.dev",
  "bugs": {
    "url": "https://github.com/sgedda/mockifyer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgedda/mockifyer.git"
  }
}
