{
  "name": "mockifyer-web",
  "version": "1.0.0",
  "description": "Example Express.js API using mockifyer for testing and development",
  "main": "dist/index.js",
  "engines": {
    "node": "20.19.5",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "preinstall": "rm -f package-lock.json package-lock.prod.json || true",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "tsc",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@sgedda/mockifyer-core": "^1.6.1",
    "@sgedda/mockifyer-axios": "^1.6.0",
    "@sgedda/mockifyer-fetch": "^1.6.1",
    "axios": "^1.6.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
} 