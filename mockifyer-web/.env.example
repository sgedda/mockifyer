# Environment Variables for Express API Mock Example
# Copy this file to .env for local development
# For Railway deployment, set these variables in the Railway dashboard: Service → Variables

# ============================================
# REQUIRED - API Keys
# ============================================
WEATHER_API_KEY=your_weather_api_key_here
FOOTBALL_API_KEY=your_football_api_key_here

# ============================================
# REQUIRED - Server Configuration
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# REQUIRED - GitHub Packages Authentication
# ============================================
# Create a GitHub Personal Access Token with 'read:packages' scope
# at https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_token_with_read_packages_scope

# ============================================
# Mockifyer Configuration
# ============================================
# Enable Mockifyer
MOCKIFYER_ENABLED=true

# Recording mode: Set to 'true' initially to record mocks, then 'false' to use recorded mocks
MOCKIFYER_RECORD=false

# Path to mock data directory
# Local development: ./mock-data or ./persisted/mock-data
# Railway deployment: /persisted/mock-data (must match volume mount path)
MOCKIFYER_PATH=/persisted/mock-data

# Optional: Redis-backed storage for mocks (Node + fetch + databaseProvider.type='redis')
# Example local Redis (e.g. `docker compose up redis` from repo root):
MOCKIFYER_REDIS_URL=redis://127.0.0.1:6379

# ============================================
# OPTIONAL - Scenario Limits
# ============================================
# Maximum number of scenarios allowed (no limit if not set)
MOCKIFYER_MAX_SCENARIOS=3

# Maximum number of requests per scenario (no limit if not set)
MOCKIFYER_MAX_REQUESTS_PER_SCENARIO=20

# ============================================
# Railway Deployment Notes
# ============================================
# 1. Set all variables in Railway dashboard: Service → Variables
# 2. Ensure MOCKIFYER_PATH matches your volume mount path (default: /persisted/mock-data)
# 3. Set MOCKIFYER_RECORD=true initially to record mocks, then change to false
# 4. GITHUB_TOKEN is required to install @sgedda/mockifyer-core / @sgedda/mockifyer-axios / @sgedda/mockifyer-fetch from GitHub Packages
