# Exclude persisted directory - it should only exist in Railway volume, not in Docker image
# If we include it in the image, Docker will copy empty files into the volume on first mount,
# overwriting any existing data
persisted/

# Standard ignores
node_modules
dist
coverage
*.log
.env
.env.local
.git
.gitignore

# Test files
*.test.ts
*.test.js
tests/
e2e/

# Development files
.vscode
.idea
*.swp
*.swo
*~

# Build artifacts that will be regenerated
coverage/
playwright-report/
test-results/

# Documentation (not needed in production image)
*.md
!README.md

# Source files (only need dist/)
src/
frontend/src/
frontend/public/

# Lock files (will be regenerated)
package-lock.json
package-lock.prod.json

