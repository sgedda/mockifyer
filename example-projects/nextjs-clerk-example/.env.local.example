# Recommended once you OAuth or expose the app beyond your laptop — https://authjs.dev/getting-started/environment-variables
AUTH_SECRET=

# Production / `next start` only: enable the passwordless "demo user" path (omit in production for real apps)
# AUTH_ALLOW_DEMO=true

# Canonical app URL when not inferrable — https://authjs.dev/getting-started/deployment
# AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client IDs → Web application)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (Developer settings → OAuth Apps → New OAuth App)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: scenario folder under ./mock-data/<name>
# MOCKIFYER_SCENARIO=default

# Optional explicit mock root (defaults to ./mock-data)
# MOCKIFYER_PATH=./mock-data

# For dev:proxy / dev:proxy:record — dashboard origin (mockifyer-dashboard)
# MOCKIFYER_PROXY_URL=http://localhost:3002
