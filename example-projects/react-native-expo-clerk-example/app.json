{
  "expo": {
    "name": "Mockifyer Expo (demo login)",
    "slug": "mockifyer-expo-clerk-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.mockifyer.clerk"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.example.mockifyer.clerk"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "mockifyer-clerk-example"
  }
}
