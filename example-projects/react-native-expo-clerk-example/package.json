{
  "name": "react-native-expo-clerk-example",
  "version": "1.0.0",
  "description": "React Native Expo + Clerk + Mockifyer (login, dashboard, varied APIs)",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "EXPO_PUBLIC_MOCKIFYER_BACKEND=hybrid MOCKIFYER_MODE=on expo start",
    "dev:hybrid": "EXPO_PUBLIC_MOCKIFYER_BACKEND=hybrid MOCKIFYER_MODE=on expo start",
    "dev:hybrid:record": "EXPO_PUBLIC_MOCKIFYER_BACKEND=hybrid MOCKIFYER_MODE=on EXPO_PUBLIC_MOCKIFYER_RECORD=true MOCKIFYER_RECORD=true expo start",
    "dev:redis": "EXPO_PUBLIC_MOCKIFYER_BACKEND=redis MOCKIFYER_MODE=on expo start",
    "dev:redis:record": "EXPO_PUBLIC_MOCKIFYER_BACKEND=redis MOCKIFYER_MODE=on EXPO_PUBLIC_MOCKIFYER_RECORD=true MOCKIFYER_RECORD=true expo start",
    "dev:off": "EXPO_PUBLIC_MOCKIFYER_BACKEND=hybrid MOCKIFYER_MODE=off expo start",
    "switch:local": "node scripts/switch-packages.js local && npm install",
    "switch:published": "node scripts/switch-packages.js published && npm install",
    "switch:status": "node scripts/switch-packages.js status",
    "dashboard": "mockifyer-dashboard --path ./mock-data --port 3002",
    "dashboard:redis": "MOCKIFYER_REDIS_URL=redis://127.0.0.1:6379 mockifyer-dashboard --provider redis --port 3002",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down",
    "redis:logs": "docker compose logs -f redis",
    "sync:mocks": "mockifyer-sync-from-device --path ./mock-data",
    "sync:mocks:ios": "mockifyer-sync-from-device --path ./mock-data --ios",
    "sync:mocks:android": "mockifyer-sync-from-device --path ./mock-data --android",
    "generate:build-data": "mockifyer --input ./mock-data --output ./assets/mock-data.ts --format typescript",
    "generate:build-data:custom": "ts-node scripts/generate-build-data.ts",
    "prebuild": "npm run generate:build-data",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@clerk/clerk-expo": "^2.14.23",
    "@clerk/expo-passkeys": "^0.0.16",
    "@sgedda/mockifyer-core": "file:../../packages/mockifyer-core",
    "@sgedda/mockifyer-dashboard": "file:../../packages/mockifyer-dashboard",
    "@sgedda/mockifyer-fetch": "file:../../packages/mockifyer-fetch",
    "expo": "~51.0.0",
    "expo-apple-authentication": "~7.1.2",
    "expo-auth-session": "~5.5.2",
    "expo-crypto": "~13.0.2",
    "expo-file-system": "~17.0.0",
    "expo-local-authentication": "~14.0.1",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-web-browser": "~13.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/react": "~18.2.79",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "node-fetch": "^2.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "private": true
}
