{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "es2019",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2019", "dom"],
    "types": ["node", "jest"],
    "baseUrl": ".",
    "paths": {
      "@sgedda/mockifyer": ["../../src"],
      "@sgedda/mockifyer/*": ["../../src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
} 