{
  "name": "express-api-mock-example",
  "version": "1.0.0",
  "description": "Example Express.js API using mockifyer for testing and development",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec 'ts-node -r tsconfig-paths/register' src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:prod": "cp package.prod.json package.json && cp tsconfig.prod.json tsconfig.json && npm install && npm run build",
    "deploy:prepare": "npm run build:prod && rm -rf node_modules && npm install --production",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@sgedda/mockifyer": "file:../../",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
