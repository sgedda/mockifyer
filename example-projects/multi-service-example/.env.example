# Copy to `.env.local` in `apps/web` if you prefer env files over npm script defaults.

# Shared lane — use the same value on web, gateway-api, relay-axios-api, and catalog-api
MOCKIFYER_CLIENT_ID=multi-service-demo

# Shared mock root (absolute path recommended if you start processes from different cwd values)
# MOCKIFYER_PATH=/absolute/path/to/example-projects/multi-service-example/mock-data

MOCKIFYER_RUNTIME=filesystem
# Must be `true` in each process that should persist mocks (web, gateway, relay, catalog).
MOCKIFYER_RECORD=false

# Internal URLs (defaults match package.json dev scripts)
GATEWAY_URL=http://127.0.0.1:4101
RELAY_URL=http://127.0.0.1:4103
CATALOG_URL=http://127.0.0.1:4102

# Optional: dashboard Redis proxy (run `npm run dashboard:redis` from this folder)
# MOCKIFYER_RUNTIME=proxy
# MOCKIFYER_PROXY_URL=http://127.0.0.1:3002
